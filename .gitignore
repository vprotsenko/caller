fs/directory/default/*.xml
__pycache__/
*.pyc
*.wav
.pytest_cache/
-creds.txt
# Test-only dialplan stubs (loopback operator simulation, §16)
fs/dialplan/public/test_*.xml
fs/sip_profiles/external/test_*.xml
