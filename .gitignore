.env
# Runtime state volumes — the SQLite DB holds SIP passwords in plaintext.
data/
audio/
# Generated operator extensions + trunk gateways (contain SIP passwords;
# written by the app at runtime)
fs/directory/default/*.xml
fs/sip_profiles/external/gw_profile_*.xml
__pycache__/
*.pyc
*.wav
.pytest_cache/
-creds.txt
# Test-only dialplan stubs (loopback operator simulation)
fs/dialplan/public/test_*.xml
fs/sip_profiles/external/test_*.xml
