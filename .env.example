# Copy to .env and fill in. .env is in .gitignore — do NOT commit it.

# --- Web UI (Basic Auth; no TLS — add a reverse proxy before production) ----
WEB_USER=admin
WEB_PASSWORD=

# --- Event Socket (FreeSWITCH <-> controller, listens on 127.0.0.1 only) ----
ESL_PASSWORD=

# --- First SIP trunk (FlySIP). Injected into the FreeSWITCH config ----------
# (fs/vars.xml reads these variables at container start). Empty values =
# the gateway comes up with placeholders and does not register (enough for tests).
SIP_SERVER=
SIP_PORT=5060
SIP_USER=
SIP_PASSWORD=

# --- Network -----------------------------------------------------------------
# Public IP of the host if it is behind NAT. Empty = auto (local IP).
EXTERNAL_IP=

# --- TTS ----------------------------------------------------------------------
LANG_CODE=uk

# --- Dialing ------------------------------------------------------------------
# Dial string template: {gw} = gateway generated from the selected SIP profile,
# {number} = the number. Leave it unset — the default sofia/gateway/{gw}/{number} kicks in.
# For E2E tests without a trunk (verification level 4): loopback/{number}/default
# DIAL_STRING_TEMPLATE=sofia/gateway/{gw}/{number}

# Caller ID the trunk sees. WITHOUT it many providers reject outbound
# calls (CALL_REJECTED / 403) — put the number (DID) issued by the provider here.
CALLER_ID_NUMBER=
CALLER_ID_NAME=
