# Скопіюй у .env і заповни. .env у .gitignore — НЕ комітити.

# --- Веб-інтерфейс (Basic Auth; без TLS — до продакшену reverse proxy) ------
WEB_USER=admin
WEB_PASSWORD=

# --- Event Socket (FreeSWITCH <-> контролер, слухає тільки 127.0.0.1) -------
ESL_PASSWORD=

# --- Перший SIP-транк (FlySIP). Підставляється у конфіг FreeSWITCH ----------
# (fs/vars.xml читає ці змінні при старті контейнера). Порожні значення =
# gateway піднімається з заглушками і не реєструється (досить для тестів).
SIP_SERVER=
SIP_PORT=5060
SIP_USER=
SIP_PASSWORD=

# --- Мережа ------------------------------------------------------------------
# Публічний IP хоста, якщо він за NAT. Порожньо = авто (локальний IP).
EXTERNAL_IP=

# --- TTS ----------------------------------------------------------------------
LANG_CODE=uk

# --- Набір --------------------------------------------------------------------
# Шаблон dial string: {gw} = gateway, згенерований з обраного SIP-профілю,
# {number} = номер. Лиши порожнім — спрацює дефолт sofia/gateway/{gw}/{number}.
# Для E2E-тестів без транка (Plan.md §16 рівень 4): loopback/{number}/default
# DIAL_STRING_TEMPLATE=sofia/gateway/{gw}/{number}

# Caller ID, який бачить транк. БЕЗ нього багато провайдерів ріжуть вихідні
# дзвінки (CALL_REJECTED / 403) — постав сюди номер (DID), виданий провайдером.
CALLER_ID_NUMBER=
CALLER_ID_NAME=
