<!-- The dialplan is almost empty: outbound calls are created by the
     controller via originate; the call is driven by ESL, not by the dialplan. -->
<include>
  <!-- Context for loopback E2E tests without a trunk (verification level 4):
       originate loopback/9999/default &playback(...) — the B leg answers and
       parks, the A leg plays the WAV; no external call at all. -->
  <context name="default">
    <extension name="loopback_test_answer">
      <condition field="destination_number" expression="^9999$">
        <action application="answer"/>
        <action application="park"/>
      </condition>
    </extension>
  </context>

  <!-- Inbound from the trunk: the dialer only places calls itself, we route
       nothing. The glob below picks up extra files (incl. the test stubs). -->
  <context name="public">
    <X-PRE-PROCESS cmd="include" data="public/*.xml"/>
  </context>
</include>
