<!-- The single SIP profile: outbound calls through a gateway (FlySIP) +
     registrations of operator softphones. Trimmed-down vanilla external;
     SIP TLS is not enabled — see docs/security.md. -->
<profile name="external">
  <gateways>
    <X-PRE-PROCESS cmd="include" data="external/*.xml"/>
  </gateways>

  <settings>
    <!-- sip-trace=yes: the SIP exchange with the trunk is written to the log
         (diagnostics of real calls — the exact cause of the provider's 4xx
         rejections). Can be switched yes→no once calls are stable. -->
    <param name="debug" value="0"/>
    <param name="sip-trace" value="yes"/>
    <param name="sip-capture" value="no"/>
    <!-- DTMF via RFC2833 only (events in RTP) — the stage 2 IVR menu feeds on this -->
    <param name="rfc2833-pt" value="101"/>
    <param name="dtmf-type" value="rfc2833"/>
    <param name="dtmf-duration" value="2000"/>

    <param name="sip-port" value="$${external_sip_port}"/>
    <param name="dialplan" value="XML"/>
    <param name="context" value="public"/>

    <param name="inbound-codec-prefs" value="$${global_codec_prefs}"/>
    <param name="outbound-codec-prefs" value="$${outbound_codec_prefs}"/>
    <param name="inbound-codec-negotiation" value="generous"/>
    <param name="inbound-late-negotiation" value="true"/>

    <param name="rtp-timer-name" value="soft"/>
    <param name="rtp-timeout-sec" value="300"/>
    <param name="rtp-hold-timeout-sec" value="1800"/>
    <!-- Do NOT treat a=sendonly/inactive as hold. FlySIP sends
         a=sendonly in early media (ringback), which made FreeSWITCH mute our
         sending direction (recvonly) so the message never got through. With
         disable-hold the media stays sendrecv after the answer. -->
    <param name="disable-hold" value="true"/>

    <param name="manage-presence" value="false"/>
    <param name="nonce-ttl" value="60"/>
    <!-- outbound trunk: inbound INVITEs are not authenticated (we don't expect
         them from outside anyway; operator registrations are stage 3, where
         auth-calls will be revisited) -->
    <param name="auth-calls" value="false"/>

    <!-- NAT: ext-* = public IP from .env (EXTERNAL_IP) or auto.
         The first thing that breaks on a real call — check it right away. -->
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="ext-rtp-ip" value="$${external_ip}"/>
    <param name="ext-sip-ip" value="$${external_ip}"/>
  </settings>
</profile>
