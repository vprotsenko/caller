<!-- Єдиний SIP-профіль: вихідні дзвінки через gateway (FlySIP) + реєстрації
     операторських софтфонів (етап 3). Обрізаний vanilla external (без TLS —
     POC-трейдоф, Plan.md §12). -->
<profile name="external">
  <gateways>
    <X-PRE-PROCESS cmd="include" data="external/*.xml"/>
  </gateways>

  <settings>
    <!-- sip-trace=yes: SIP-обмін із транком пишеться в лог (діагностика
         реальних дзвінків — точна причина 4xx-відмов провайдера). Можна
         вимкнути на yes→no, коли дзвінки стабільні. -->
    <param name="debug" value="0"/>
    <param name="sip-trace" value="yes"/>
    <param name="sip-capture" value="no"/>
    <!-- DTMF тільки RFC2833 (events у RTP) — IVR-меню етапу 2 живиться цим -->
    <param name="rfc2833-pt" value="101"/>
    <param name="dtmf-type" value="rfc2833"/>
    <param name="dtmf-duration" value="2000"/>

    <param name="sip-port" value="$${external_sip_port}"/>
    <param name="dialplan" value="XML"/>
    <param name="context" value="public"/>

    <param name="inbound-codec-prefs" value="$${global_codec_prefs}"/>
    <param name="outbound-codec-prefs" value="$${outbound_codec_prefs}"/>
    <param name="inbound-codec-negotiation" value="generous"/>
    <param name="inbound-late-negotiation" value="true"/>

    <param name="rtp-timer-name" value="soft"/>
    <param name="rtp-timeout-sec" value="300"/>
    <param name="rtp-hold-timeout-sec" value="1800"/>
    <!-- НЕ трактувати a=sendonly/inactive як «утримання» (hold). FlySIP шле
         a=sendonly у ранньому медіа (ringback), через що FreeSWITCH глушив наш
         передавальний напрямок (recvonly) і повідомлення не доходило. З
         disable-hold медіа лишається sendrecv після відповіді. -->
    <param name="disable-hold" value="true"/>

    <param name="manage-presence" value="false"/>
    <param name="nonce-ttl" value="60"/>
    <!-- вихідний транк: вхідні INVITE не автентифікуємо (їх і не очікуємо
         ззовні; реєстрації операторів — етап 3, там auth-calls переглянеться) -->
    <param name="auth-calls" value="false"/>

    <!-- NAT: ext-* = публічний IP з .env (EXTERNAL_IP) або auto.
         Перше, що ламається на реальному дзвінку — перевіряти одразу (§12). -->
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="ext-rtp-ip" value="$${external_ip}"/>
    <param name="ext-sip-ip" value="$${external_ip}"/>
  </settings>
</profile>
