<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <!-- Loopback ONLY: ESL authenticates nothing except the password.
         The controller lives in the same network namespace (host network on
         Linux / service:freeswitch in the macOS override). Do NOT expose externally. -->
    <param name="listen-ip" value="127.0.0.1"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="$${esl_password}"/>
  </settings>
</configuration>
