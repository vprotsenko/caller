<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <!-- ТІЛЬКИ loopback: ESL не автентифікує нічого, крім пароля.
         Контролер живе в тому самому network namespace (host network на
         Linux / service:freeswitch у macOS-оверрайді). НЕ відкривати назовні. -->
    <param name="listen-ip" value="127.0.0.1"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="$${esl_password}"/>
  </settings>
</configuration>
