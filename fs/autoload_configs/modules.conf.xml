<configuration name="modules.conf" description="Modules">
  <modules>
    <!-- logging: console (stdout) + logfile (/var/log/freeswitch/freeswitch.log)
         for diagnosing real calls — the base safarov image starts with -nf,
         so without mod_logfile call history is not stored anywhere. -->
    <load module="mod_console"/>
    <load module="mod_logfile"/>
    <!-- core API + ESL -->
    <load module="mod_commands"/>
    <load module="mod_event_socket"/>
    <!-- SIP + test loopback endpoint (verification level 4) -->
    <load module="mod_sofia"/>
    <load module="mod_loopback"/>
    <!-- dialplan + applications (playback, park, bridge...) -->
    <load module="mod_dialplan_xml"/>
    <load module="mod_dptools"/>
    <!-- audio: WAV files + tone/silence -->
    <load module="mod_sndfile"/>
    <load module="mod_tone_stream"/>
    <!-- AMD (stage 4): mod_avmd — voicemail beep detection; mod_amd —
         HUMAN/MACHINE classification. mod_amd exists only in the
         caller-freeswitch:amd image (Dockerfile.freeswitch); the base safarov
         image lacks it — loading yields a NON-fatal warning, and the controller
         treats the answer as HUMAN (does not hang up the call). -->
    <load module="mod_avmd"/>
    <load module="mod_amd"/>
  </modules>
</configuration>
