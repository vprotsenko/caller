<configuration name="modules.conf" description="Modules">
  <modules>
    <!-- logging: console (stdout) + logfile (/var/log/freeswitch/freeswitch.log)
         для діагностики реальних дзвінків — base safarov-образ стартує з -nf,
         тож без mod_logfile історія дзвінків ніде не зберігається. -->
    <load module="mod_console"/>
    <load module="mod_logfile"/>
    <!-- core API + ESL -->
    <load module="mod_commands"/>
    <load module="mod_event_socket"/>
    <!-- SIP + тестовий loopback-ендпойнт (§16 рівень 4) -->
    <load module="mod_sofia"/>
    <load module="mod_loopback"/>
    <!-- dialplan + аплікації (playback, park, bridge...) -->
    <load module="mod_dialplan_xml"/>
    <load module="mod_dptools"/>
    <!-- аудіо: WAV-файли + тон/тиша -->
    <load module="mod_sndfile"/>
    <load module="mod_tone_stream"/>
    <!-- AMD (етап 4): mod_avmd — детекція біпа голосової пошти; mod_amd —
         класифікація HUMAN/MACHINE. mod_amd є лише в образі
         caller-freeswitch:amd (Dockerfile.freeswitch); у базовому safarov-образі
         його нема — завантаження дасть НЕфатальне попередження, а контролер
         трактує відповідь як HUMAN (не скидає дзвінок). -->
    <load module="mod_avmd"/>
    <load module="mod_amd"/>
  </modules>
</configuration>
