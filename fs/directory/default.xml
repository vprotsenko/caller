<!-- Домен для операторських extension'ів. Файли default/<ext>.xml генерує
     контролер (POST /config/operators + reloadxml, Plan.md §15); вони містять
     SIP-паролі операторів і НЕ комітяться (.gitignore). -->
<include>
  <domain name="$${domain}">
    <params>
      <param name="dial-string"
             value="{presence_id=${dialed_user}@${dialed_domain}}${sofia_contact(${dialed_user}@${dialed_domain})}"/>
    </params>
    <groups>
      <group name="default">
        <users>
          <X-PRE-PROCESS cmd="include" data="default/*.xml"/>
        </users>
      </group>
    </groups>
  </domain>
</include>
