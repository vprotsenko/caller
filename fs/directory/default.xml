<!-- Domain for operator extensions. The default/<ext>.xml files are generated
     by the controller (POST /config/operators + reloadxml); they
     contain operators' SIP passwords and are NOT committed (.gitignore). -->
<include>
  <domain name="$${domain}">
    <params>
      <param name="dial-string"
             value="{presence_id=${dialed_user}@${dialed_domain}}${sofia_contact(${dialed_user}@${dialed_domain})}"/>
    </params>
    <groups>
      <group name="default">
        <users>
          <X-PRE-PROCESS cmd="include" data="default/*.xml"/>
        </users>
      </group>
    </groups>
  </domain>
</include>
